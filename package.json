{
    "name": "@tak-ps/cloudtak-desktop",
    "version": "1.1.0",
    "description": "CloudTAK Desktop Application",
    "main": "index.js",
    "scripts": {
        "prestart": "npm run build:setup-ui",
        "start": "electron . --no-sandbox",
        "build:setup-ui": "cd setup-ui && npm install && npm run build",
        "build": "npm run build:setup-ui && electron-builder -mwl",
        "cap:sync": "npm run build:setup-ui && npx cap sync",
        "cap:ios": "npm run cap:sync && npx cap open ios",
        "cap:android": "npm run cap:sync && npx cap open android",
        "cap:run:ios": "npm run cap:sync && npx cap run ios",
        "cap:run:android": "npm run cap:sync && npx cap run android",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "build": {
        "appId": "com.cloudtak.desktop",
        "productName": "cloudtak",
        "directories": {
            "output": "dist"
        },
        "mac": {
            "category": "public.app-category.utilities",
            "extendInfo": {
                "NSLocationWhenInUseUsageDescription": "CloudTAK needs your location to show your position on the map.",
                "NSLocationAlwaysAndWhenInUseUsageDescription": "CloudTAK needs your location to show your position on the map."
            }
        },
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "artifactName": "cloudtak-desktop_${version}_${arch}.${ext}"
        }
    },
    "keywords": [],
    "author": {
        "name": "Nick Ingalls",
        "email": "nick@ingalls.ca"
    },
    "homepage": "https://github.com/dfpc-coe/CloudTAK",
    "license": "AGPL",
    "type": "commonjs",
    "devDependencies": {
        "@capacitor/cli": "^8.1.0",
        "electron": "^40.6.0",
        "electron-builder": "^26.8.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@capacitor-community/keep-awake": "^8.0.0",
        "@capacitor/android": "^8.1.0",
        "@capacitor/browser": "^8.0.1",
        "@capacitor/core": "^8.1.0",
        "@capacitor/geolocation": "^8.1.0",
        "@capacitor/ios": "^8.1.0",
        "@capacitor/preferences": "^8.0.1",
        "electron-serve": "^3.0.1"
    }
}
